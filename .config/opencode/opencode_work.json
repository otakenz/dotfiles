{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": false,
	"share": "disabled",
	"model": "opencode/big-pickle",
	"agent": {
		"compaction": {
			"model": "opencode/big-pickle",
			"auto": false,
			"prune": true,
			"reserved": 10000
		}
	},
	"mcp": {
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp"
		},
		"sequentialthinking": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"mcp/sequentialthinking:latest"
			]
		},
		"mcp-atlassian": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"--env-file",
				"{env:HOME}/.config/secret/mcp-atlassian/.env",
				"ghcr.io/sooperset/mcp-atlassian:latest"
			]
		},
		"github": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"--env-file",
				"{env:HOME}/.config/secret/github/.env",
				"ghcr.io/github/github-mcp-server:latest"
			]
		}
	},
	"tools": {
		"mcp-atlassian*": false,
		"github*": false
	},
	"plugin": [
		"oh-my-openagent",
		"superpowers@git+https://github.com/obra/superpowers.git"
	],
	"provider": {
		"aumovio-vio": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "AUMOVIO VIO",
			"options": {
				"baseURL": "https://vio.automotive-wan.com:446",
				"apiKey": "{env:VIO_API_TOKEN}"
			},
			"models": {
				"VIO:Claude 4.6 Sonnet": {
					"name": "Claude Sonnet 4.6",
					"limit": {
						"context": 1000000,
						"output": 64000
					},
					"modalities": {
						"input": ["text", "image", "pdf"],
						"output": ["text"]
					},
					"variants": {
						"medium": { "reasoningEffort": "medium" },
						"high": { "reasoningEffort": "high" },
						"xhigh": { "reasoningEffort": "xhigh" },
						"max": { "reasoningEffort": "max" }
					}
				},
				"VIO:Claude 4.6 opus": {
					"name": "Claude Opus 4.6",
					"limit": {
						"context": 1000000,
						"output": 128000
					},
					"modalities": {
						"input": ["text", "image", "pdf"],
						"output": ["text"]
					},
					"variants": {
						"medium": { "reasoningEffort": "medium" },
						"high": { "reasoningEffort": "high" },
						"xhigh": { "reasoningEffort": "xhigh" },
						"max": { "reasoningEffort": "max" }
					}
				},
				"VIO:DeepSeek V4 Pro": {
					"name": "DeepSeek V4 Pro",
					"limit": {
						"context": 1000000,
						"output": 383000
					},
					"modalities": {
						"input": ["text"],
						"output": ["text"]
					}
				}
			}
		}
	}
}
