{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": false,
	"share": "disabled",
	"model": "opencode/big-pickle",
	"agent": {
		"compaction": {
			"model": "opencode/big-pickle",
			"auto": false,
			"prune": true,
			"reserved": 10000
		}
	},
	"mcp": {
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp"
		},
		"sequentialthinking": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"mcp/sequentialthinking:latest"
			]
		},
		"mcp-atlassian": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"--env-file",
				"{env:HOME}/.config/secret/mcp-atlassian/.env",
				"ghcr.io/sooperset/mcp-atlassian:latest"
			]
		},
		"github": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"--env-file",
				"{env:HOME}/.config/secret/github/.env",
				"ghcr.io/github/github-mcp-server:latest"
			]
		}
	},
	"tools": {
		"mcp-atlassian*": false,
		"github*": false
	},
	"plugin": [
		"oh-my-openagent",
		"superpowers@git+https://github.com/obra/superpowers.git"
	],
	"provider": {
		"aumovio-vio": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "AUMOVIO VIO",
			"options": {
				"baseURL": "https://vio.automotive-wan.com:446",
				"apiKey": "{env:VIO_API_TOKEN}",
				"headers": {
					"Authorization": "Bearer {env:VIO_API_TOKEN}",
					"useLegacyCompletionsEndpoint": "false",
					"X-Tenant-ID": "default_tenant",
					"username": "{env:VIO_API_USERNAME}",
					"token": "{env:VIO_API_TOKEN}"
				}
			},
			"models": {
				"VIO:Claude 4.5 Sonnet": {
					"name": "Claude Sonnet 4.5",
					"limit": {
						"context": 200000,
						"output": 64000
					}
				},
				"VIO:Claude 4.5 opus": {
					"name": "Claude Opus 4.5",
					"limit": {
						"context": 200000,
						"output": 64000
					},
					"modalities": {
						"input": ["text", "image"],
						"output": ["text"]
					}
				},
				"VIO:Grok-4-fast-non-reasoning": {
					"name": "Grok 4 fast (Non-Reasoning)",
					"limit": {
						"context": 200000,
						"output": 30000
					}
				},
				"VIO:Gpt-5.1": {
					"name": "GPT 5.1",
					"limit": {
						"context": 400000,
						"output": 128000
					}
				},
				"VIO:GPT-5-high": {
					"name": "GPT 5 (high)",
					"limit": {
						"context": 400000,
						"output": 128000
					}
				},
				"VIO:GPT-OSS-120B": {
					"name": "GPT OSS 120B",
					"limit": {
						"context": 131072,
						"output": 131072
					}
				}
			}
		}
	}
}
